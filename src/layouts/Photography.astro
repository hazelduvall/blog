---
import type { DefaultProps } from "../models/Default";
import Page from "./Page.astro";

type Props = DefaultProps;
---

<Page
  {...Astro.props}
  inList={true}
  previous={{
    url: "/photography.html",
    title: "Main Photography Page",
  }}
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Hazel Duvall's Photography"
      href="https://www.hazelduvall.dev/photography/rss.xml"
    />
  </Fragment>
  <slot />
</Page>
